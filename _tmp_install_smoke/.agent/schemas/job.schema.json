{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dotagent job record",
  "type": "object",
  "required": ["id", "type", "status", "created_at", "input", "output", "metadata"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["task", "review"]
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "RUNNING", "SUCCESS", "FAILED", "REVIEWED", "CANCELLED"]
    },
    "created_at": {
      "type": "string"
    },
    "input": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" },
        "prompt_template": { "type": ["string", "null"] },
        "prompt_file": { "type": ["string", "null"] },
        "base_prompt": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "properties": {
        "output_file": { "type": ["string", "null"] },
        "events_file": { "type": ["string", "null"] },
        "stderr_file": { "type": ["string", "null"] },
        "artifacts_index": { "type": ["string", "null"] },
        "exit_code": { "type": ["integer", "null"] },
        "started_at": { "type": ["string", "null"] },
        "completed_at": { "type": ["string", "null"] },
        "prompt_preview": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "properties": {
        "workflow_id": { "type": ["string", "null"] },
        "stage": { "type": ["string", "null"] },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_bundle": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}


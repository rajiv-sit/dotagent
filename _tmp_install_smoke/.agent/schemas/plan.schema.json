{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dotagent PLAN.md working execution tracker",
  "type": "object",
  "properties": {
    "current_objective": {
      "type": "string",
      "description": "One short statement of the active goal"
    },
    "completed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Finished work items"
    },
    "in_progress": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": { "type": "string" },
          "start_date": { "type": "string" },
          "owner": { "type": "string" }
        }
      },
      "description": "Currently active items with start date and optional owner"
    },
    "next": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Planned work items in priority order"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue": { "type": "string" },
          "impact": { "type": "string" },
          "workaround": { "type": "string" }
        }
      },
      "description": "Work items that are blocked with impact and optional workaround"
    },
    "verification": {
      "type": "object",
      "properties": {
        "tests_run": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manual_checks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "known_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "description": "Verification status and gaps"
    }
  },
  "additionalProperties": true
}


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dotcodex requirement document",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Document title"
    },
    "overview": {
      "type": "object",
      "properties": {
        "purpose": {
          "type": "string",
          "description": "What the system is for and who it serves"
        },
        "scope": {
          "type": "string",
          "description": "Bounded scope of requirements"
        }
      }
    },
    "functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "success_criteria": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["performance", "scalability", "usability", "reliability", "security", "maintainability"]
          },
          "requirement": {
            "type": "string"
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "glossary": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

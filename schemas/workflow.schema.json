{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dotagent workflow record",
  "type": "object",
  "required": ["id", "type", "created_at", "objective", "status", "jobs", "edges"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "workflow"
    },
    "created_at": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "RUNNING", "SUCCESS", "FAILED", "REVIEWED"]
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "job_id", "dependencies"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": ["HLD", "DD", "CODE", "TEST", "REVIEW"]
          },
          "job_id": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

